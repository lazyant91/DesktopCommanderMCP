{
  "name": "@lazyant91/local-mcp-server",
  "version": "0.1.0",
  "description": "Standalone stdio MCP server for local terminal sessions and filesystem operations",
  "mcpName": "io.github.lazyant91/local-mcp-server",
  "license": "MIT",
  "author": "lazyant91",
  "contributors": [
    {
      "name": "Eduards Ruzga",
      "url": "https://github.com/wonderwhy-er"
    }
  ],
  "homepage": "https://github.com/lazyant91/DesktopCommanderMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/lazyant91/DesktopCommanderMCP.git"
  },
  "bugs": "https://github.com/lazyant91/DesktopCommanderMCP/issues",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "local-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:debug": "node --inspect-brk=9229 dist/index.js",
    "prepare": "npm run build",
    "clean": "shx rm -rf dist",
    "test": "npm run build && node test/run-all-tests.js",
    "test:integration": "npm run build && node test/integration/run-all-integration-tests.js",
    "test:debug": "node --inspect test/run-all-tests.js",
    "link:local": "npm run build && npm link",
    "unlink:local": "npm unlink",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "local-mcp",
    "stdio",
    "terminal",
    "process-session",
    "filesystem",
    "file-editing"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "isbinaryfile": "^5.0.4",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.24",
    "shx": "^0.3.4",
    "typescript": "^5.3.3"
  }
}
